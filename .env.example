# ─── Antigravity v4 — Webhook Bot — Environment Variables ────────────────────
# Copy this to .env for local testing.
# On Railway: paste each variable in the service Variables tab (NOT as a file).

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a random string, e.g.:  openssl rand -hex 16
# Paste the SAME value in:
#   1. This var (Railway)
#   2. Pine Script input: "Webhook Secret"
WEBHOOK_SECRET=change_me_to_something_random

# ─── Trading Mode ─────────────────────────────────────────────────────────────
# true  → paper trade only (safe, just logs signals, no orders placed)
# false → live execution on Bitget Futures
PAPER_TRADING=true

# ─── Capital & Risk ───────────────────────────────────────────────────────────
PORTFOLIO_VALUE_USD=200
MAX_RISK_PCT=1
MAX_LEVERAGE=5

# ─── Circuit Breakers (kill switches) ─────────────────────────────────────────
MAX_DD_PCT=15
MAX_DAILY_LOSS_PCT=3
MAX_TRADES_PER_DAY=5
COOLDOWN_SECONDS=1800

# ─── Bitget API (only needed when PAPER_TRADING=false) ────────────────────────
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=
